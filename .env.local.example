# Supabase — copy this file to .env.local and fill in your project values.
# Find these in your Supabase dashboard: Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Anthropic Claude API — powers the LinkUpNaija AI chatbot.
# Get a key at https://console.anthropic.com → Settings → API Keys
ANTHROPIC_API_KEY=sk-ant-your-api-key

# Paystack — public key for paid events & featured-event payments.
# Find it in your Paystack dashboard → Settings → API Keys & Webhooks
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your-paystack-public-key

# --- Edge Function secrets (set via `supabase secrets set`, NOT here) ---
# RESEND_API_KEY   — for the daily event-reminder emails (https://resend.com)
# REMINDER_FROM    — e.g. "LinkUpNaija <events@yourdomain.com>"
